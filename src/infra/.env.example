# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
#
# These are needed at CDK synth/deploy time.
# In CI, they are injected by GitHub Actions (variables and secrets).

# ── Required ────────────────────────────────────────────────────────────────

# Your 12-digit AWS account ID.
# GitHub Actions: set as a repository variable named AWS_ACCOUNT_ID.
AWS_ACCOUNT_ID=

# ── Optional ────────────────────────────────────────────────────────────────

# Comma-separated list of additional CORS origins for dev environment.
# Useful for Vercel preview deployments, staging environments, etc.
# Example: https://frontend-admin-ecru.vercel.app,https://preview.example.com
DEV_CORS_ORIGINS=https://frontend-admin-ecru.vercel.app

# ── Prod only ────────────────────────────────────────────────────────────────

# Email address that receives CloudWatch alarm notifications.
# GitHub Actions: set as a secret in the production environment named ALERT_EMAIL.
ALERT_EMAIL=

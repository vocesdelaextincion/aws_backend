# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
#
# These are injected automatically by CDK when Lambdas run in AWS.
# You only need this file for running Lambda handlers locally during development.
#
# All values come from the deployed stack — run after first deploy:
#   aws ssm get-parameter --name /voces/dev/cognito/user-pool-id --query Parameter.Value
#   aws ssm get-parameter --name /voces/dev/cognito/user-pool-client-id --query Parameter.Value
#   aws ssm get-parameter --name /voces/dev/dynamodb/table-name --query Parameter.Value
#   aws ssm get-parameter --name /voces/dev/s3/bucket-name --query Parameter.Value

# ── Shared (all functions) ────────────────────────────────────────────────────

ENV=dev
TABLE_NAME=voces-dev-main

# ── Auth + Admin functions ────────────────────────────────────────────────────

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ── Recordings function ───────────────────────────────────────────────────────

S3_BUCKET_NAME=voces-dev-recordings

# Presigned URL expiry in seconds. Defaults match what CDK sets.
PRESIGNED_URL_TTL_FREE=900
PRESIGNED_URL_TTL_PREMIUM=3600
